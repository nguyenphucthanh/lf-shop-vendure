{
  "name": "littleflockshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "test:consignment-services": "node --test -r ts-node/register test/consignment-services.test.ts",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "typecheck": "tsc --noEmit",
    "typecheck:plugins": "tsc -p tsconfig.plugins.json",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:plugins": "eslint src/plugins --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "check:plugins": "npm run typecheck:plugins && npm run lint:plugins",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@vendure/asset-server-plugin": "3.6.2",
    "@vendure/core": "3.6.2",
    "@vendure/dashboard": "3.6.2",
    "@vendure/email-plugin": "3.6.2",
    "@vendure/graphiql-plugin": "3.6.2",
    "dotenv": "17.4.2",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vendure/cli": "3.6.2",
    "concurrently": "9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  }
}
