{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "paths": {
      "@/gql": ["./src/gql/graphql.ts"],
      "@/vdb/*": ["./node_modules/@vendure/dashboard/src/lib/*"]
    }
  },
  "include": ["src/plugins/**/dashboard/**/*", "src/gql/**/*.ts", "vite.*.*ts"]
}
