# Production Environment Variables
# Copy this file to .env and update with your production values

# ============================================
# Database Configuration
# ============================================
DB_NAME=vendure
DB_USERNAME=vendure
DB_PASSWORD=your-secure-password-here

# ============================================
# Superadmin Credentials (CHANGE THESE!)
# ============================================
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=your-secure-superadmin-password-here

# ============================================
# Security
# ============================================
COOKIE_SECRET=your-long-random-secure-cookie-secret-here

# ============================================
# Email Configuration
# ============================================
# SMTP Server settings for transactional emails
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM_ADDRESS="your-store@example.com"

# ============================================
# Application Environment
# ============================================
APP_ENV=prod
NODE_ENV=production
LOG_LEVEL=info
